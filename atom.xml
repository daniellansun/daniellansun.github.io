  <entry>
    <title>浅谈网络架构分层设计</title>
    <link href="https://blog.sunlan.me/2023/12/18/%E6%B5%85%E8%B0%88%E7%BD%91%E7%BB%9C%E6%9E%B6%E6%9E%84%E5%88%86%E5%B1%82%E8%AE%BE%E8%AE%A1/"/>
